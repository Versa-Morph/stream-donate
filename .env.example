APP_NAME=StreamDonate
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Cache TTL settings (in seconds)
CACHE_STREAMER_STATS_TTL=15
CACHE_STREAMER_STATS_RECENT=60
CACHE_STREAMER_STATS_IDLE=180
CACHE_STREAMER_STATS_INACTIVE=300
CACHE_PROFANITY_FILTER_TTL=300
CACHE_WIDGET_SETTINGS_TTL=60

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ──────────────────────────────────────────────────────────────────────────────
# Donation Settings
# ──────────────────────────────────────────────────────────────────────────────
# Maximum donation amount in IDR (default: 100,000,000 = 100 million rupiah)
DONATION_MAX_AMOUNT=100000000
DONATION_CURRENCY=IDR

# ──────────────────────────────────────────────────────────────────────────────
# OTP Settings
# ──────────────────────────────────────────────────────────────────────────────
OTP_LENGTH=8
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=3

VITE_APP_NAME="${APP_NAME}"
