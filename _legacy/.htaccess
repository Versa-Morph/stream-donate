# ============================================================
# LEGACY CODE - ACCESS BLOCKED
# ============================================================
# This directory contains legacy code that is no longer in use.
# All access is blocked for security reasons.
# 
# The legacy code has several security vulnerabilities:
# - Wildcard CORS headers (Access-Control-Allow-Origin: *)
# - Unsafe file_get_contents() on user-controlled paths
# - No authentication or rate limiting
#
# If you need to access this code for migration purposes,
# temporarily comment out the Deny rules below.
# ============================================================

# Block all access to this directory
<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order deny,allow
    Deny from all
</IfModule>

# Fallback: Also use mod_rewrite to block access
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule .* - [F,L]
</IfModule>
